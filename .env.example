# ─── NVIDIA Startup AI Radar — configuração ───
# NADA aqui é obrigatório para o NÚCLEO (scoring, gold eval, IPI, mapa) rodar.
# As chaves abaixo apenas HABILITAM camadas extras. O sistema degrada graciosamente.

# LLM (habilita agentes Extractor/Classifier/Recommender/Briefing)
OPENROUTER_API_KEY=
RADAR_LLM_MODEL=anthropic/claude-sonnet-4.5
RADAR_LLM_FAST_MODEL=anthropic/claude-haiku-4.5
# Alternativa coerente com a stack NVIDIA (Nemotron via build.nvidia.com):
NVIDIA_API_KEY=
# RADAR_LLM_MODEL=nvidia/nemotron-4-super

# RAG / reranking (habilita busca na base NVIDIA)
COHERE_API_KEY=
RADAR_EMBED_MODEL=BAAI/bge-m3
RADAR_RERANK_MODEL=nvidia/llama-3.2-nv-rerankqa-1b-v2

# Descoberta (sinais primários — os de maior valor)
GITHUB_TOKEN=
HUGGINGFACE_TOKEN=

# Scraping / busca web (enriquecimento)
FIRECRAWL_API_KEY=
TAVILY_API_KEY=

# Persistência (SQLite por padrão; troque por Postgres em produção)
DATABASE_URL=
