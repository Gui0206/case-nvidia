# =========================================================================
#  NVIDIA Startup AI Radar  —  environment configuration
#  Copy to ".env" and fill in. Only OPENROUTER_API_KEY is required.
# =========================================================================

# ---- LLM (REQUIRED) — all models are served through OpenRouter -----------
OPENROUTER_API_KEY=sk-or-...
# Reasoning model (planner, classifier, recommender, briefing)
RADAR_LLM_MODEL=anthropic/claude-sonnet-4.6
# Fast/cheap model (extraction, validation — high volume)
RADAR_LLM_FAST_MODEL=anthropic/claude-haiku-4.5
# Optional attribution headers shown on OpenRouter
OPENROUTER_APP_URL=https://github.com/Gui0206/case_nvidia
OPENROUTER_APP_TITLE=NVIDIA Startup AI Radar

# ---- Web search for startup discovery (OPTIONAL) ------------------------
# If unset, free DuckDuckGo search is used automatically.
TAVILY_API_KEY=

# ---- Clean web extraction (OPTIONAL) ------------------------------------
# If set, Firecrawl is preferred for fetching pages.
FIRECRAWL_API_KEY=

# ---- Reranking (OPTIONAL) -----------------------------------------------
# If set, Cohere Rerank is used; otherwise a local ONNX cross-encoder runs.
COHERE_API_KEY=
RADAR_COHERE_RERANK_MODEL=rerank-v3.5

# ---- Structured store (OPTIONAL) ----------------------------------------
# Default is local SQLite. Set a Postgres URL to use PostgreSQL instead.
# DATABASE_URL=postgresql://user:pass@localhost:5432/radar

# ---- RAG tuning (OPTIONAL) ----------------------------------------------
RADAR_EMBED_MODEL=BAAI/bge-small-en-v1.5
RADAR_RERANK_LOCAL_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
RADAR_RAG_TOP_K=5
RADAR_RAG_CANDIDATES=20
